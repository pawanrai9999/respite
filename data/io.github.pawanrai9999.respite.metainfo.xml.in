<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.pawanrai9999.respite</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>AGPL-3.0-or-later</project_license>

  <name>Respite</name>
  <summary>Take regular breaks from the screen</summary>
  <description>
    <p>
      Respite helps you protect your eyes, posture, and focus by enforcing
      regular breaks while you work. You set how long you want to work and how
      long each break should last, and Respite takes care of the rest.
    </p>
    <p>
      When the work interval elapses, Respite blacks out every monitor with a
      centered countdown until the break is over. Breaks are not infinitely
      dismissible: a limited, configurable number of postponements lets you
      delay an urgent moment without skipping breaks entirely.
    </p>
    <p>Features:</p>
    <ul>
      <li>Configurable work interval and break duration</li>
      <li>Full-screen break overlay across every connected monitor</li>
      <li>Pre-break warning with a limited postpone allowance</li>
      <li>Runs quietly in the background and can start on login</li>
    </ul>
  </description>

  <screenshots>
    <screenshot type="default">
      <image>https://raw.githubusercontent.com/pawanrai9999/respite/main/data/screenshots/preferences.png</image>
      <caption>Set your work interval, break length, and postpone allowance</caption>
    </screenshot>
    <screenshot>
      <image>https://raw.githubusercontent.com/pawanrai9999/respite/main/data/screenshots/break.png</image>
      <caption>A full-screen countdown covers every monitor during a break</caption>
    </screenshot>
  </screenshots>

  <developer id="io.github.pawanrai9999">
    <name>Pawan</name>
  </developer>

  <url type="homepage">https://github.com/pawanrai9999/respite</url>
  <url type="vcs-browser">https://github.com/pawanrai9999/respite</url>
  <url type="bugtracker">https://github.com/pawanrai9999/respite/issues</url>

  <translation type="gettext">respite</translation>
  <!-- All graphical applications having a desktop file must have this tag in the MetaInfo.
     If this is present, appstreamcli compose will pull icons, keywords and categories from the desktop file. -->
  <launchable type="desktop-id">io.github.pawanrai9999.respite.desktop</launchable>
  <!-- Use the OARS website (https://hughsie.github.io/oars/generate.html) to generate these and make sure to use oars-1.1 -->
  <content_rating type="oars-1.1" />

  <branding>
    <color type="primary" scheme_preference="light">#62a0ea</color>
    <color type="primary" scheme_preference="dark">#1a5fb4</color>
  </branding>

  <releases>
    <release version="0.2.0" date="2026-06-18">
      <description translate="no">
        <ul>
          <li>Play a sound cue when a break starts and when it ends</li>
        </ul>
      </description>
    </release>
    <release version="0.1.0" date="2026-06-17">
      <description translate="no">
        <p>Initial release.</p>
        <ul>
          <li>Configurable work/break timer engine</li>
          <li>Full-screen break overlay with a live countdown on every monitor</li>
          <li>Pre-break warning notification with a limited postpone allowance</li>
          <li>Background daemon mode with optional start on login</li>
        </ul>
      </description>
    </release>
  </releases>

</component>
